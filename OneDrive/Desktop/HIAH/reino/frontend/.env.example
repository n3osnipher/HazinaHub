# ── Reino Frontend Environment Variables ──────────────────────────
# Copy to .env.local for local dev, or set in Vercel dashboard for production

# Backend API URL (leave empty for local dev with Vite proxy)
# For production on Vercel, set this to your Render backend URL:
# VITE_API_URL=https://reino-backend.onrender.com
VITE_API_URL=
